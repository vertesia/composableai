{
    "name": "@koa-stack/router",
    "version": "0.24.0",
    "description": "A powerfull koa router using typescript decorations",
    "main": "./lib/cjs/index.js",
    "type": "module",
    "scripts": {
        "build": "pnpm exec tsmod build",
        "clean": "rimraf ./lib",
        "test": "vitest run"
    },
    "files": [
        "lib",
        "src"
    ],
    "keywords": [
        "koa",
        "router",
        "typescript",
        "decorations"
    ],
    "author": "stefanescu.bogdan@gmail.com",
    "license": "MIT",
    "dependencies": {
        "koa": "^3.2.1",
        "koa-compose": "^4.1.0",
        "koa-send": "^5.0.1",
        "path-to-regexp": "^6.2.2",
        "statuses": "^2.0.1"
    },
    "devDependencies": {
        "@types/koa": "^3.0.3",
        "@types/koa-compose": "^3.2.8",
        "@types/koa-send": "^4.1.3",
        "@types/statuses": "^2.0.1",
        "ts-dual-module": "^0.6.3",
        "vitest": "^4.0.0"
    },
    "ts_dual_module": {
        "outDir": "lib"
    },
    "exports": {
        "types": "./lib/types/index.d.ts",
        "import": "./lib/esm/index.js",
        "require": "./lib/cjs/index.js"
    },
    "types": "./lib/types/index.d.ts"
}
