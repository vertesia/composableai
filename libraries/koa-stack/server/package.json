{
    "name": "@koa-stack/server",
    "version": "0.25.0",
    "description": " A web server based on koa with advanced routing, lazy body and flexbile error handling",
    "type": "module",
    "scripts": {
        "clean:lib": "rimraf ./lib ./tsconfig.tsbuildinfo",
        "build": "pnpm run clean:lib && tsc -p tsconfig.json",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo",
        "test": "echo \"Error: no test specified\""
    },
    "files": [
        "lib",
        "src"
    ],
    "keywords": [
        "web",
        "server",
        "koa"
    ],
    "author": "stefanescu.bogdan@gmail.com",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "libraries/koa-stack/server"
    },
    "dependencies": {
        "@koa-stack/body": "workspace:*",
        "@koa-stack/router": "workspace:*",
        "koa": "^3.2.1"
    },
    "devDependencies": {
        "@types/koa": "^3.0.3",
        "@vertesia/tsconfig": "workspace:*",
        "typescript": "^6.0.3"
    },
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    }
}
