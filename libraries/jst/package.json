{
    "name": "@vertesia/jst",
    "version": "1.3.0",
    "type": "module",
    "description": "Javascript text template",
    "license": "Apache-2.0",
    "homepage": "https://docs.vertesiahq.com",
    "files": [
        "lib",
        "src"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "libraries/jst"
    },
    "keywords": [
        "vertesia",
        "template",
        "handlebars",
        "jst",
        "javascript",
        "prompt"
    ],
    "scripts": {
        "lint": "biome lint src",
        "test": "vitest run",
        "build": "tsc && pnpm exec rollup -c",
        "clean": "rm -rf ./lib tsconfig.tsbuildinfo",
        "typecheck": "tsc --noEmit",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
    },
    "peerDependencies": {
        "handlebars": ">=4.0.0"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@types/estree": "^1.0.8",
        "@types/papaparse": "^5.5.1",
        "@vertesia/tsconfig": "workspace:*",
        "rollup": "^4.60.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "@types/node": "^24.1.0",
        "acorn": "8.15.0",
        "acorn-walk": "8.3.4",
        "dayjs": "^1.11.19",
        "papaparse": "^5.5.3"
    },
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    }
}
