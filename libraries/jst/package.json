{
    "name": "@vertesia/jst",
    "version": "1.3.0",
    "type": "module",
    "description": "Javascript text template",
    "main": "./lib/index.js",
    "license": "Apache-2.0",
    "homepage": "https://docs.vertesiahq.com",
    "files": [
        "lib",
        "src"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "libraries/jst"
    },
    "keywords": [
        "vertesia",
        "template",
        "handlebars",
        "jst",
        "javascript",
        "prompt"
    ],
    "scripts": {
        "preinstall": "pnpm exec only-allow pnpm",
        "lint": "biome lint src",
        "test": "vitest run",
        "build": "pnpm exec tsmod build",
        "clean": "rm -rf ./lib tsconfig.tsbuildinfo",
        "typecheck": "tsc --noEmit",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
    },
    "peerDependencies": {
        "handlebars": ">=4.0.0"
    },
    "devDependencies": {
        "@types/estree": "^1.0.8",
        "@types/papaparse": "^5.5.1",
        "ts-dual-module": "^0.6.3",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "@types/node": "^24.1.0",
        "acorn": "8.15.0",
        "acorn-walk": "8.3.4",
        "papaparse": "^5.5.3",
        "cheerio": "^1.1.2",
        "dayjs": "^1.11.19"
    },
    "ts_dual_module": {
        "outDir": "lib"
    },
    "exports": {
        "types": "./lib/types/index.d.ts",
        "default": "./lib/esm/index.js",
        "import": "./lib/esm/index.js",
        "require": "./lib/cjs/index.js"
    },
    "types": "./lib/types/index.d.ts"
}
