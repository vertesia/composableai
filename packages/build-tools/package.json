{
    "name": "@vertesia/build-tools",
    "version": "1.5.0-dev",
    "description": "Build tools for Vertesia projects - import transformers (skill / template / prompt / raw), esbuild widget bundler, vertesia-build CLI, and a Vite dev plugin",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "bin": {
        "vertesia-build": "lib/bin/build.js"
    },
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "lint": "biome lint src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
        "clean:lib": "rimraf ./lib ./tsconfig.tsbuildinfo",
        "build": "pnpm run clean:lib && tsc -p tsconfig.json && chmod +x ./lib/bin/build.js",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./vite": {
            "types": "./lib/vite/index.d.ts",
            "default": "./lib/vite/index.js"
        }
    },
    "devDependencies": {
        "@hono/node-server": "^2.0.5",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^24.13.2",
        "@vertesia/tsconfig": "workspace:*",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "@llumiverse/common": "workspace:*",
        "@rollup/plugin-commonjs": "^28.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^12.1.2",
        "@vertesia/common": "workspace:*",
        "@vertesia/studio-utils": "workspace:*",
        "esbuild": "^0.28.1",
        "js-yaml": "^4.2.0",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "@hono/node-server": "^2.0.5",
        "vite": "^8.0.16"
    },
    "peerDependenciesMeta": {
        "@hono/node-server": {
            "optional": true
        },
        "vite": {
            "optional": true
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/build-tools"
    },
    "keywords": [
        "vertesia",
        "vite",
        "vite-plugin",
        "build-tools",
        "imports",
        "transform",
        "esbuild",
        "skill",
        "markdown",
        "frontmatter",
        "widget",
        "bundler",
        "zod",
        "validation"
    ]
}
