{
    "name": "@vertesia/build-tools",
    "version": "1.3.0",
    "description": "Build tools for Vertesia projects - Rollup and Vite plugins for transforming imports, bundling skills, and compiling widgets",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "lint": "biome lint src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
        "build": "rm -rf ./lib ./tsconfig.tsbuildinfo && tsc && pnpm exec rollup -c",
        "clean": "rm -rf ./node_modules ./lib ./tsconfig.tsbuildinfo"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./vite": {
            "types": "./lib/vite.d.ts",
            "default": "./lib/vite.js"
        }
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/node": "^24.12.4",
        "@vertesia/tsconfig": "workspace:*",
        "rollup": "^4.60.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "@llumiverse/common": "workspace:*",
        "@rollup/plugin-commonjs": "^28.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^12.1.2",
        "@vertesia/common": "workspace:*",
        "gray-matter": "^4.0.3",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "rollup": "^4.60.4"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/build-tools"
    },
    "keywords": [
        "vertesia",
        "rollup",
        "rollup-plugin",
        "vite",
        "vite-plugin",
        "build-tools",
        "imports",
        "transform",
        "compiler",
        "skill",
        "markdown",
        "frontmatter",
        "widget",
        "bundler",
        "zod",
        "validation"
    ]
}
