{
  "name": "@vertesia/build-tools",
  "version": "1.2.0",
  "description": "Build tools for Vertesia projects - Rolldown and Vite plugins for transforming imports, bundling skills, and compiling widgets",
  "type": "module",
  "main": "./lib/esm/index.js",
  "types": "./lib/types/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "lint": "biome lint src",
    "test": "vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "build": "tsmod build && rolldown -c rollup.config.js",
    "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo"
  },
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./vite": {
      "types": "./lib/types/vite.d.ts",
      "import": "./lib/esm/vite.js",
      "require": "./lib/cjs/vite.js"
    }
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "rolldown": "^1.0.2",
    "ts-dual-module": "^0.6.3",
    "typescript": "^6.0.2",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@llumiverse/common": "workspace:*",
    "@vertesia/common": "workspace:*",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "rolldown": "^1.0.0",
    "vite": "^8.0.0"
  },
  "ts_dual_module": {
    "outDir": "lib"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vertesia/composableai.git",
    "directory": "packages/build-tools"
  },
  "keywords": [
    "vertesia",
    "rolldown",
    "rolldown-plugin",
    "vite",
    "vite-plugin",
    "build-tools",
    "imports",
    "transform",
    "compiler",
    "skill",
    "markdown",
    "frontmatter",
    "widget",
    "bundler",
    "zod",
    "validation"
  ]
}
