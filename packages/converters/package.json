{
    "name": "@vertesia/converters",
    "version": "1.5.0-dev",
    "description": "Image and content converters",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "lint": "biome lint src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
        "build": "rm -rf ./lib ./tsconfig.tsbuildinfo && tsc --build",
        "clean": "rm -rf ./node_modules ./lib ./tsconfig.tsbuildinfo"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "devDependencies": {
        "@types/tmp": "^0.2.6",
        "@vertesia/tsconfig": "workspace:*",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "sharp": "^0.34.5",
        "tmp": "^0.2.7"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/converters"
    },
    "keywords": [
        "vertesia",
        "converters",
        "image",
        "pdf",
        "markdown",
        "sharp",
        "pandoc",
        "mutool",
        "typescript"
    ]
}
