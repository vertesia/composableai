{
    "name": "@vertesia/client",
    "version": "1.3.0",
    "type": "module",
    "types": "./lib/types/index.d.ts",
    "files": [
        "lib",
        "src",
        "tsconfig.dist.json"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "lint": "biome lint src",
        "build": "pnpm exec tsmod build && pnpm exec rollup -c",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/node": "^24.12.4",
        "rollup": "^4.60.4",
        "ts-dual-module": "^0.6.3",
        "typescript": "^6.0.3",
        "vitest": "^4.0.16"
    },
    "dependencies": {
        "@llumiverse/common": "workspace:*",
        "@vertesia/api-fetch-client": "workspace:*",
        "@vertesia/common": "workspace:*",
        "eventsource": "^4.1.0"
    },
    "ts_dual_module": {
        "outDir": "lib"
    },
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "import": "./lib/esm/index.js",
            "require": "./lib/cjs/index.js"
        },
        "./package.json": "./package.json",
        "./node": {
            "types": "./lib/types/nodejs/index.d.ts",
            "import": "./lib/esm/nodejs/index.js",
            "require": "./lib/cjs/nodejs/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/client"
    },
    "keywords": [
        "vertesia",
        "client",
        "api",
        "sdk",
        "llm",
        "ai",
        "typescript"
    ],
    "typesVersions": {
        "*": {
            "node": [
                "./lib/types/nodejs/index.d.ts"
            ]
        }
    }
}
