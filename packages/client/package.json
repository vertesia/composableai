{
    "name": "@vertesia/client",
    "version": "1.5.0-dev",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src",
        "tsconfig.dist.json"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "lint": "biome lint src",
        "clean:lib": "rimraf ./lib ./tsconfig.tsbuildinfo",
        "build": "pnpm run clean:lib && tsc -p tsconfig.json && pnpm exec rollup -c",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@types/node": "^24.13.2",
        "@vertesia/tsconfig": "workspace:*",
        "rollup": "^4.62.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "@llumiverse/common": "workspace:*",
        "@vertesia/api-fetch-client": "workspace:*",
        "@vertesia/common": "workspace:*",
        "eventsource": "^4.1.0"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./package.json": "./package.json",
        "./node": {
            "types": "./lib/nodejs/index.d.ts",
            "default": "./lib/nodejs/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/client"
    },
    "keywords": [
        "vertesia",
        "client",
        "api",
        "sdk",
        "llm",
        "ai",
        "typescript"
    ]
}
