{
    "name": "@vertesia/tools-sdk",
    "version": "1.5.0-dev",
    "description": "Tools SDK - utilities for building remote tools",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "lint": "biome lint src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
        "clean:lib": "rimraf ./lib ./tsconfig.tsbuildinfo",
        "build": "pnpm run clean:lib && tsc -p tsconfig.json",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@vertesia/tsconfig": "workspace:*",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "peerDependencies": {
        "hono": "^4.12.25"
    },
    "dependencies": {
        "@llumiverse/common": "workspace:*",
        "@vertesia/client": "workspace:*",
        "@vertesia/common": "workspace:*",
        "jose": "^6.2.3",
        "zod": "^4.4.3"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/tools-sdk"
    },
    "keywords": [
        "vertesia",
        "tools",
        "sdk",
        "llm",
        "ai",
        "agents",
        "typescript"
    ]
}
