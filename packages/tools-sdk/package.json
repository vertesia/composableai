{
    "name": "@vertesia/tools-sdk",
    "version": "1.3.0",
    "description": "Tools SDK - utilities for building remote tools",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "lint": "biome lint src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
        "build": "rm -rf ./lib ./tsconfig.tsbuildinfo && tsc",
        "clean": "rm -rf ./node_modules ./lib ./tsconfig.tsbuildinfo"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "devDependencies": {
        "@types/node": "^24.12.4",
        "@vertesia/tsconfig": "workspace:*",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "peerDependencies": {
        "hono": "^4.12.23"
    },
    "dependencies": {
        "@llumiverse/common": "workspace:*",
        "@vertesia/client": "workspace:*",
        "@vertesia/common": "workspace:*",
        "jose": "^6.2.3",
        "zod": "^4.4.3"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/tools-sdk"
    },
    "keywords": [
        "vertesia",
        "tools",
        "sdk",
        "llm",
        "ai",
        "agents",
        "typescript"
    ]
}
