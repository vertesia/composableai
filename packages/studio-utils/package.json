{
    "name": "@vertesia/studio-utils",
    "version": "1.3.0",
    "type": "module",
    "description": "Shared utilities for Vertesia studio: prompt template rendering, schema-based mock data generation, prompt and interaction validation helpers.",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "license": "Apache-2.0",
    "homepage": "https://docs.vertesiahq.com",
    "files": [
        "lib",
        "src"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/studio-utils"
    },
    "keywords": [
        "vertesia",
        "studio",
        "prompt",
        "template",
        "handlebars",
        "jst",
        "validation"
    ],
    "scripts": {
        "lint": "biome lint src",
        "test": "vitest run",
        "build": "pnpm exec tsc && pnpm exec rollup -c",
        "clean": "rm -rf ./lib ./tsconfig.tsbuildinfo && pnpm exec tsc && pnpm exec rollup -c"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@types/node": "^24.12.4",
        "@vertesia/tsconfig": "workspace:*",
        "rollup": "^4.60.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "@llumiverse/common": "workspace:*",
        "@vertesia/common": "workspace:*",
        "@vertesia/jst": "workspace:*",
        "handlebars": "^4.7.9"
    }
}
