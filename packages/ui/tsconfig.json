{
    "extends": "@vertesia/tsconfig/ui-lib.json",
    "compilerOptions": {
        "paths": {
            "@vertesia/ui/*": ["./src/*"]
        },
        "rootDir": "./src",
        "outDir": "./lib"
    },
    "include": ["src", "src/i18n/locales/*.json"],
    "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx", "src/__tests__/**", "lib", "test"],
    "references": [
        { "path": "../common" },
        { "path": "../client" },
        { "path": "../json" },
        { "path": "../rich-text" }
    ]
}
