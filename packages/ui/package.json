{
    "name": "@vertesia/ui",
    "version": "1.5.0-dev",
    "description": "Vertesia UI components and and hooks",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src",
        "tsconfig.dist.json",
        "llms.txt"
    ],
    "license": "Apache-2.0",
    "homepage": "https://docs.vertesiahq.com",
