{
    "name": "@vertesia/fusion-ux",
    "version": "1.5.0-dev.20260714.072725Z",
    "description": "Dynamic model-generated UI components for Vertesia",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "homepage": "https://docs.vertesiahq.com",
    "keywords": [
        "vertesia",
        "fusion",
        "ui",
        "dynamic",
        "model-generated",
        "react"
    ],
    "scripts": {
        "clean:lib": "rimraf ./lib ./tsconfig.tsbuildinfo",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo",
        "build": "pnpm run clean:lib && tsc -p tsconfig.json && pnpm exec rolldown -c rolldown.config.js",
        "lint": "biome lint src",
        "lint:fix": "biome lint --write src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
    },
    "dependencies": {
        "@vertesia/common": "workspace:*",
        "ajv": "^8.20.0",
        "react": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@vertesia/tsconfig": "workspace:*",
        "rolldown": "catalog:",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/fusion-ux"
    }
}
