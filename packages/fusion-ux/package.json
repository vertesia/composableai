{
    "name": "@vertesia/fusion-ux",
    "version": "1.4.1",
    "description": "Dynamic model-generated UI components for Vertesia",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "homepage": "https://docs.vertesiahq.com",
    "keywords": [
        "vertesia",
        "fusion",
        "ui",
        "dynamic",
        "model-generated",
        "react"
    ],
    "scripts": {
        "clean:lib": "rimraf ./lib ./tsconfig.tsbuildinfo",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo",
        "build": "pnpm run clean:lib && tsc -p tsconfig.json && pnpm exec rollup -c",
        "lint": "biome lint src",
        "lint:fix": "biome lint --write src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
    },
    "dependencies": {
        "@vertesia/common": "workspace:*",
        "ajv": "^8.20.0",
        "react": "19.2.7"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-replace": "^6.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@types/node": "^24.13.2",
        "@types/react": "19.2.17",
        "@vertesia/tsconfig": "workspace:*",
        "rollup": "^4.61.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/fusion-ux"
    }
}
