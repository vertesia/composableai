{
  "name": "@vertesia/fusion-ux",
  "version": "1.3.0",
  "description": "Dynamic model-generated UI components for Vertesia",
  "type": "module",
  "main": "./lib/esm/index.js",
  "types": "./lib/types/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "license": "Apache-2.0",
  "homepage": "https://docs.vertesiahq.com",
  "keywords": [
    "vertesia",
    "fusion",
    "ui",
    "dynamic",
    "model-generated",
    "react"
  ],
  "scripts": {
    "build": "pnpm exec rimraf ./lib && tsc -b && pnpm exec rollup -c",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "test": "vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@vertesia/common": "workspace:*",
    "ajv": "^8.20.0",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "typescript": "^6.0.3",
    "vitest": "^4.0.16"
  },
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "default": "./lib/esm/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./lib/types/index.d.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vertesia/composableai.git",
    "directory": "packages/fusion-ux"
  }
}
