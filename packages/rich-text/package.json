{
    "name": "@vertesia/rich-text",
    "version": "1.5.0-dev",
    "description": "Markdown-first rich-text editing primitives for Vertesia",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "homepage": "https://docs.vertesiahq.com",
    "keywords": [
        "vertesia",
        "markdown",
        "rich-text",
        "tiptap"
    ],
    "scripts": {
        "clean:lib": "rimraf ./lib ./tsconfig.tsbuildinfo",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo",
        "build": "pnpm run clean:lib && tsc -p tsconfig.json && pnpm exec rolldown -c rolldown.config.js",
        "lint": "biome lint src",
        "lint:fix": "biome lint --write src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
    },
    "dependencies": {
        "@tiptap/core": "^3.27.3",
        "@tiptap/extension-code-block": "^3.27.3",
        "@tiptap/extension-image": "^3.27.3",
        "@tiptap/extension-link": "^3.27.3",
        "@tiptap/extension-table": "^3.27.3",
        "@tiptap/markdown": "^3.27.3",
        "@tiptap/pm": "^3.27.3",
        "@tiptap/react": "^3.27.3",
        "@tiptap/starter-kit": "^3.27.3",
        "marked": "^17.0.1",
        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "@vertesia/tsconfig": "workspace:*",
        "rolldown": "catalog:",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/rich-text"
    }
}
