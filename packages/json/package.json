{
    "name": "@vertesia/json",
    "version": "1.3.0",
    "description": "JSON utlities",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "lint": "biome lint src",
        "test": "vitest run",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
        "build": "rm -rf ./lib ./tsconfig.tsbuildinfo && tsc && pnpm exec rollup -c",
        "clean": "rm -rf ./node_modules ./lib ./tsconfig.tsbuildinfo"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@vertesia/tsconfig": "workspace:*",
        "rollup": "^4.61.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/json"
    },
    "keywords": [
        "vertesia",
        "json",
        "utilities",
        "walker",
        "visitor",
        "traverse",
        "typescript"
    ]
}
