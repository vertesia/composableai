{
  "name": "@vertesia/json",
  "version": "1.2.0",
  "description": "JSON utlities",
  "type": "module",
  "types": "./lib/types/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "lint": "biome lint src",
    "test": "vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "build": "pnpm exec tsmod build && tsc -p tsconfig.web.json --noEmit && pnpm exec rolldown -c rollup.config.js",
    "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo"
  },
  "exports": {
    "types": "./lib/types/index.d.ts",
    "import": "./lib/esm/index.js",
    "require": "./lib/cjs/index.js"
  },
  "devDependencies": {
    "rolldown": "^1.0.2",
    "ts-dual-module": "^0.6.3",
    "typescript": "^6.0.2",
    "vitest": "^4.0.16"
  },
  "ts_dual_module": {
    "outDir": "lib"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vertesia/composableai.git",
    "directory": "packages/json"
  },
  "keywords": [
    "vertesia",
    "json",
    "utilities",
    "walker",
    "visitor",
    "traverse",
    "typescript"
  ]
}
