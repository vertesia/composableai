{
    "name": "@vertesia/api-fetch-client",
    "version": "1.5.0-dev.20260714.072725Z",
    "description": "HTTP client which wraps a fetch implementation and simplify the creation of REST API clients. Works both in browser and in node.",
    "type": "module",
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        }
    },
    "scripts": {
        "test": "ESBK_TSCONFIG_PATH=./test/tsconfig.json pnpm exec mocha -r tsx --exit ./test/**/*.ts",
        "lint": "biome lint src",
        "typecheck:test": "tsc -p test/tsconfig.json --noEmit",
        "clean:lib": "rimraf ./lib ./tsconfig.tsbuildinfo",
        "build": "pnpm run clean:lib && tsc -p tsconfig.json",
        "clean": "rimraf ./node_modules ./lib ./tsconfig.tsbuildinfo"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vertesia/composableai.git",
        "directory": "packages/api-fetch-client"
    },
    "keywords": [
        "fetch",
        "client",
        "api",
        "rest",
        "browser",
        "node",
        "sse",
        "eventsource",
        "vertesia"
    ],
    "author": "stefanescu.bogdan@gmail.com",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/vertesia/composableai/issues"
    },
    "homepage": "https://github.com/vertesia/composableai/tree/main/packages/api-fetch-client#readme",
    "devDependencies": {
        "@koa-stack/router": "workspace:*",
        "@koa-stack/server": "workspace:*",
        "@types/koa": "^3.0.3",
        "@types/mocha": "^10.0.10",
        "@types/node": "catalog:",
        "@vertesia/tsconfig": "workspace:*",
        "koa": "^3.2.1",
        "mocha": "^11.7.6",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "eventsource-parser": "^3.1.0"
    }
}
