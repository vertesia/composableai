{
  "name": "@vertesia/packages",
  "version": "1.3.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm exec turbo run build",
    "bump": "pnpm exec wst bump minor -x llumiverse",
    "ci:local": "pnpm run lint && pnpm run build && pnpm run ci:test",
    "ci:test": "pnpm exec turbo run typecheck:test test --filter='./packages/*' --filter='./llumiverse/*' --filter='./templates/*'",
    "ci:typecheck:test": "pnpm exec turbo run typecheck:test --filter='./packages/*' --filter='./llumiverse/*' --filter='./templates/*'",
    "clean": "rimraf ./node_modules && pnpm -r clean",
    "format": "pnpm exec biome format --write .",
    "format:check": "pnpm exec biome format .",
    "lint": "pnpm exec biome lint",
    "lint:fix": "pnpm exec biome lint --write",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "prepublishOnly": "pnpm build",
    "release": "pnpm -r publish --access public",
    "test": "pnpm -r test",
    "typecheck:test": "pnpm -r --if-present typecheck:test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "lint-staged": "^17.0.5",
    "npm-ws-tools": "^0.3.0",
    "rimraf": "^5.0.10",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,jsx,ts,tsx,css,html}": [
      "pnpm exec biome lint --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error"
    ]
  },
  "packageManager": "pnpm@11.1.2"
}
