# Standalone UI app configuration.
# Required by `vite dev --mode app` and `vite build --mode app`.
# This is public Vite build-time config, not a secret.
VITE_APP_NAME={{PROJECT_NAME}}

# Vertesia endpoints (region: {{REGION}}).
# Override in .env.app.local to point at a different environment.
# Names must stay aligned with src/ui/vite-env.d.ts and the env vars set by
# the appgen pipeline (publish-activities.ts + scripts/app-preview.sh).
VITE_VERTESIA_STUDIO_URL={{STUDIO_URL}}
VITE_VERTESIA_ZENO_URL={{ZENO_URL}}
VITE_VERTESIA_STS_URL={{STS_URL}}
