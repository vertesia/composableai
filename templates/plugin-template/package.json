{
    "name": "plugin-template",
    "version": "1.3.0",
    "description": "A unified template for building custom UI plugins and tool servers for Vertesia",
    "type": "module",
    "main": "lib/server.js",
    "files": [
        "dist",
        "lib"
    ],
    "author": "Vertesia",
    "license": "Apache-2.0",
    "scripts": {
        "dev": "vite dev --mode app",
        "lint": "biome lint src",
        "prebuild": "biome lint src && tsc --build --noEmit",
        "build:server": "rollup -c",
        "build:ui:app": "vite build --mode app",
        "build:ui:lib": "vite build --mode lib",
        "build:ui": "vite build --mode app && vite build --mode lib",
        "build": "rollup -c && vite build --mode app && vite build --mode lib",
        "preview": "rollup -c && vite preview",
        "start": "rollup -c && vite preview",
        "start:vercel": "vercel dev",
        "test": "echo \"(no tests in template scaffold)\""
    },
    "keywords": [
        "plugin",
        "ui-plugin",
        "tool-server",
        "hono",
        "vercel",
        "llm",
        "ai",
        "tools",
        "skills",
        "interactions",
        "mcp"
    ],
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@hono/vite-dev-server": "^0.26.0",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^24.12.4",
        "@types/react": "^19.2.3",
        "@types/react-dom": "^19.2.3",
        "@vertesia/build-tools": "workspace:*",
        "@vertesia/plugin-builder": "workspace:*",
        "@vitejs/plugin-basic-ssl": "^2.1.0",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^9.2.1",
        "globals": "^17.6.0",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "rollup": "^4.60.4",
        "tailwindcss": "^4.3.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vite-plugin-serve-static": "^2.2.0"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.4",
        "@llumiverse/common": "workspace:*",
        "@vertesia/client": "workspace:*",
        "@vertesia/common": "workspace:*",
        "@vertesia/tools-admin-ui": "workspace:*",
        "@vertesia/tools-sdk": "workspace:*",
        "@vertesia/ui": "workspace:*",
        "dotenv": "^17.4.2",
        "hono": "^4.12.23",
        "lucide-react": "^1.16.0"
    }
}
