{
  "name": "plugin-template",
  "version": "1.0.0",
  "description": "A unified template for building custom UI plugins and tool servers for Vertesia",
  "type": "module",
  "main": "lib/server.js",
  "files": [
    "dist",
    "lib"
  ],
  "author": "Vertesia",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite dev --mode app",
    "lint": "biome lint src",
    "prebuild": "biome lint src && tsc --build --noEmit",
    "build:server": "rolldown -c rollup.config.js",
    "build:ui:app": "vite build --mode app",
    "build:ui:lib": "vite build --mode lib",
    "build:ui": "vite build --mode app && vite build --mode lib",
    "build": "rolldown -c rollup.config.js && vite build --mode app && vite build --mode lib",
    "preview": "rolldown -c rollup.config.js && vite preview",
    "start": "rolldown -c rollup.config.js && vite preview",
    "start:vercel": "vercel dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "plugin",
    "ui-plugin",
    "tool-server",
    "hono",
    "vercel",
    "llm",
    "ai",
    "tools",
    "skills",
    "interactions",
    "mcp"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@hono/vite-dev-server": "^0.25.3",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vertesia/build-tools": "workspace:*",
    "@vertesia/plugin-builder": "workspace:*",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "globals": "^17.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rolldown": "^1.0.2",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.13",
    "vite-plugin-serve-static": "^2.2.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "@llumiverse/common": "workspace:*",
    "@vertesia/client": "workspace:*",
    "@vertesia/common": "workspace:*",
    "@vertesia/tools-admin-ui": "workspace:*",
    "@vertesia/tools-sdk": "workspace:*",
    "@vertesia/ui": "workspace:*",
    "dotenv": "^17.2.3",
    "hono": "^4.10.3",
    "lucide-react": "^0.562.0"
  }
}
