{
    "name": "plugin-template",
    "version": "1.4.0",
    "description": "A unified template for building custom UI plugins and tool servers for Vertesia",
    "type": "module",
    "main": "lib/server.js",
    "files": [
        "dist",
        "lib"
    ],
    "author": "Vertesia",
    "license": "Apache-2.0",
    "scripts": {
        "dev": "vite dev --mode app",
        "lint": "biome lint src",
        "prebuild": "biome lint src && tsc --build --noEmit",
        "clean:lib": "rimraf ./lib ./tsconfig.tool-server.tsbuildinfo",
        "build:server": "npm run clean:lib && tsc -p tsconfig.tool-server.json && node ./node_modules/@vertesia/build-tools/lib/bin/build.js",
        "build:ui:app": "vite build --mode app",
        "build:ui:lib": "vite build --mode lib",
        "build:ui": "vite build --mode app && vite build --mode lib",
        "build": "npm run build:server && npm run build:ui",
        "preview": "npm run build:server && vite preview",
        "start": "npm run build:server && vite preview",
        "start:vercel": "vercel dev",
        "test": "echo \"(no tests in template scaffold)\""
    },
    "vertesia-build": {
        "libDir": "./lib",
        "srcDir": "./src/tool-server",
        "transformers": [
            "skill",
            "skills",
            "template",
            "templates",
            "prompt",
            "raw"
        ],
        "assetsDir": "./dist",
        "widgetConfig": {
            "minify": false
        }
    },
    "keywords": [
        "plugin",
        "ui-plugin",
        "tool-server",
        "hono",
        "vercel",
        "llm",
        "ai",
        "tools",
        "skills",
        "interactions",
        "mcp"
    ],
    "peerDependencies": {
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.0",
        "@hono/vite-dev-server": "^0.26.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.3.1",
        "@types/node": "^24.13.2",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vertesia/build-tools": "workspace:*",
        "@vertesia/plugin-builder": "workspace:*",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^10.0.3",
        "globals": "^17.6.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "rimraf": "^6.1.3",
        "tailwindcss": "^4.3.1",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vite-plugin-serve-static": "^2.2.0"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.4",
        "@llumiverse/common": "workspace:*",
        "@vertesia/client": "workspace:*",
        "@vertesia/common": "workspace:*",
        "@vertesia/tools-admin-ui": "workspace:*",
        "@vertesia/tools-sdk": "workspace:*",
        "@vertesia/ui": "workspace:*",
        "dotenv": "^17.4.2",
        "hono": "^4.12.25",
        "lucide-react": "^1.21.0"
    }
}
