{
    "name": "plugin-template",
    "version": "1.3.0",
    "description": "A unified template for building custom UI plugins and tool servers for Vertesia",
    "type": "module",
    "main": "lib/server.js",
    "files": [
        "dist",
        "lib"
    ],
    "author": "Vertesia",
    "license": "Apache-2.0",
    "scripts": {
        "dev": "vite dev --mode app",
        "quality": "node scripts/app-quality-check.mjs",
        "typecheck": "node scripts/typecheck.mjs",
        "lint": "biome lint src",
        "check": "pnpm run lint && pnpm run typecheck && pnpm run quality",
        "build:server": "pnpm run quality && node scripts/build-server-esbuild.mjs && node scripts/write-app-package.mjs",
        "build:app": "pnpm run typecheck && vite build --mode app --outDir dist/app --emptyOutDir --minify false",
        "build:service": "pnpm run build:app && vite build --mode lib && pnpm run build:server",
        "build": "pnpm run lint && pnpm run build:service",
        "preview": "pnpm run build:service && vite preview",
        "start": "pnpm run preview",
        "start:vercel": "vercel dev",
        "test": "echo \"(no tests in template scaffold)\""
    },
    "vertesia-build": {
        "libDir": "./lib",
        "srcDir": "./src/tool-server",
        "transformers": [
            "skill",
            "skills",
            "template",
            "templates",
            "prompt",
            "raw"
        ],
        "assetsDir": "./dist",
        "widgetConfig": {
            "minify": false
        }
    },
    "keywords": [
        "plugin",
        "ui-plugin",
        "tool-server",
        "hono",
        "vercel",
        "llm",
        "ai",
        "tools",
        "skills",
        "interactions",
        "mcp"
    ],
    "peerDependencies": {
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "@hono/vite-dev-server": "^0.26.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vertesia/build-tools": "workspace:*",
        "@vertesia/plugin-builder": "workspace:*",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^10.0.3",
        "esbuild": "^0.28.0",
        "globals": "^17.6.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwindcss": "^4.3.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vite-plugin-serve-static": "^2.2.0"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.4",
        "@llumiverse/common": "workspace:*",
        "@vertesia/client": "workspace:*",
        "@vertesia/common": "workspace:*",
        "@vertesia/tools-admin-ui": "workspace:*",
        "@vertesia/tools-sdk": "workspace:*",
        "@vertesia/ui": "workspace:*",
        "dotenv": "^17.4.2",
        "hono": "^4.12.25",
        "html-parse-stringify": "^3.0.1",
        "lucide-react": "^1.17.0",
        "react-vega": "^8.0.0",
        "use-sync-external-store": "^1.6.0",
        "vega": "^6.2.0",
        "vega-embed": "^7.1.0",
        "vega-lite": "^6.4.3"
    }
}
