{
  "name": "plugin-template",
  "version": "1.0.0",
  "description": "A unified template for building custom UI plugins and tool servers for Vertesia",
  "type": "module",
  "main": "lib/server.js",
  "files": [
    "dist",
    "lib"
  ],
  "author": "Vertesia",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite dev --mode app",
    "prebuild": "pnpm run lint && tsc --build --noEmit",
    "build": "pnpm run build:server && pnpm run build:ui",
    "build:server": "rollup -c",
    "build:ui": "pnpm run build:ui:app && pnpm run build:ui:lib",
    "build:ui:app": "vite build --mode app",
    "build:ui:lib": "vite build --mode lib",
    "start": "pnpm run preview",
    "start:vercel": "vercel dev",
    "lint": "eslint .",
    "preview": "pnpm run build:server && vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "plugin",
    "ui-plugin",
    "tool-server",
    "hono",
    "vercel",
    "llm",
    "ai",
    "tools",
    "skills",
    "interactions",
    "mcp"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hono/vite-dev-server": "^0.25.1",
    "@rollup/plugin-commonjs": "^28.0.8",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vertesia/build-tools": "workspace:*",
    "@vertesia/plugin-builder": "workspace:*",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rollup": "^4.60.1",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.0",
    "vite-plugin-serve-static": "^1.2.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "@llumiverse/common": "workspace:*",
    "@vertesia/client": "workspace:*",
    "@vertesia/common": "workspace:*",
    "@vertesia/tools-admin-ui": "workspace:*",
    "@vertesia/tools-sdk": "workspace:*",
    "@vertesia/ui": "workspace:*",
    "dotenv": "^17.2.3",
    "hono": "^4.10.3",
    "lucide-react": "^0.562.0"
  }
}
