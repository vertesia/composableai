{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "lib/**",
        "tsconfig.tsbuildinfo",
        ".tsbuildinfo"
      ]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}
