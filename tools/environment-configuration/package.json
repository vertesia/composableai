{
  "name": "environment-configuration",
  "version": "0.0.1",
  "description": "A collection of scripts to automate the configuration of execution environments in Vertesia",
  "license": "Apache-2.0",
  "author": "Vertesia",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "biome lint src",
    "format": "biome format --write src",
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "aws": "npx bun ./src/index.ts aws",
    "gcp": "npx bun ./src/index.ts gcp"
  },
    "devDependencies": {
        "@biomejs/biome": "^2.4.4",
        "@tsconfig/node-lts": "^22.0.1",
        "@types/bun": "latest",
        "globals": "^17.3.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.948.0",
    "@vertesia/client": "0.82.1",
    "commander": "^14.0.2",
    "dotenv": "^16.6.1",
    "google-auth-library": "^10.6.2"
  }
}
