{
  "name": "environment-configuration",
  "version": "0.0.1",
  "description": "A collection of scripts to automate the configuration of execution environments in Vertesia",
  "license": "Apache-2.0",
  "author": "Vertesia",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "biome lint src",
    "format": "biome format --write src",
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "aws": "npx bun ./src/index.ts aws",
    "gcp": "npx bun ./src/index.ts gcp"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/bun": "^1.3.14",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.948.0",
    "@vertesia/client": "1.3.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2"
  }
}
